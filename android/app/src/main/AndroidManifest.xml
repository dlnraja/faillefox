<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dlnraja.faillefox">

    <!-- Faillefox intercepte le trafic via un VPN local (VpnService).
         C'est l'approche imposée par Android pour filtrer par application
         (cf. NetGuard, RethinkDNS). Aucune donnée ne quitte l'appareil. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Faillefox"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight">

        <!-- Le VPN : intercepte le trafic réseau de toutes les apps, applique
             les règles du moteur Faillefox, puis renvoie le trafic autorisé. -->
        <service
            android:name=".vpn.FaillefoxVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
